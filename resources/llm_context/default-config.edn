{:analysis
 {:include ["."]
  :exclude [".git" ".llm-context" "node_modules" "target" ".cpcache"
            "dist" "build" "out" ".shadow-cljs" ".cljs_node_repl" ".lsp"]
  :languages :auto
  :max-file-bytes 1048576}

 :store
 {:path ".llm-context/db"}

 :semantic
 {:providers [:scip-typescript]
  :scip-typescript-command ["npx" "--no-install" "scip-typescript" "index"]}

 :context
 {:default-max-tokens 8000
  :trace-depth 4}}
