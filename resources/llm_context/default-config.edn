{:analysis
 {:include ["."]
  :exclude [".git" ".llm-context" "node_modules" "target" ".cpcache"
            "dist" "build" "out" ".shadow-cljs" ".cljs_node_repl" ".lsp"]
  :languages :auto
  :max-file-bytes 1048576}

 :store
 {:path ".llm-context/db"}

 :semantic
 {:providers [:scip-typescript :lateon-code]
  :scip-typescript-command ["npx" "--no-install" "scip-typescript" "index"]
  :lateon-code
  {:enabled true
   :mode :background
   :next-plaid-version "1.6.4"
   :next-plaid-command ["next-plaid-api"]
   :model "lightonai/LateOn-Code"
   :model-revision "734b659a57935ef50562d79581c3ff1f8d825c93"
   :model-path nil
   :quantization :int8
   :index-path ".llm-context/semantic/next-plaid"
   :index-name "llm-context"
   :nbits 4
   :start-from-scratch 0
   :document-version 1
   :max-document-bytes 6000
   :chunk-overlap-lines 8
   :pool-factor 2
   :encoding-sessions 1
   :encoding-batch-size 1
   :model-document-length 2048
   :update-batch-size 10
   :startup-timeout-ms 120000
   :health-timeout-ms 2000
   :update-timeout-ms 120000
   :query-timeout-ms 350
   :candidate-count 50
   :n-ivf-probe 8
   :centroid-score-threshold nil
   :n-full-scores 4096
   :lease-ms 120000
   :visibility-timeout-ms 180000
   :visibility-poll-ms 250
   :idle-poll-ms 500
   :retry-base-ms 1000
   :retry-max-ms 60000
   :max-attempts 5}}

 :context
 {:default-max-tokens 8000
  :trace-depth 4}}
