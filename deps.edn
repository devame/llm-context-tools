{:paths ["src" "resources"]
 :deps {org.clojure/clojure {:mvn/version "1.12.0"}
        org.clojure/data.json {:mvn/version "2.5.1"}
        org.datalevin/datalevin-embedded {:mvn/version "1.0.0"}
        io.github.tree-sitter/jtreesitter {:mvn/version "0.26.1"}
        io.github.bonede/tree-sitter {:mvn/version "0.25.3"}
        io.github.bonede/tree-sitter-javascript
        {:mvn/version "0.23.1"
         :exclusions [io.github.bonede/tree-sitter]}
        io.github.bonede/tree-sitter-typescript
        {:mvn/version "0.23.2" :exclusions [io.github.bonede/tree-sitter]}
        io.github.bonede/tree-sitter-python
        {:mvn/version "0.23.4" :exclusions [io.github.bonede/tree-sitter]}
        io.github.bonede/tree-sitter-java
        {:mvn/version "0.23.4" :exclusions [io.github.bonede/tree-sitter]}
        io.github.bonede/tree-sitter-go
        {:mvn/version "0.23.3" :exclusions [io.github.bonede/tree-sitter]}
        io.github.bonede/tree-sitter-rust
        {:mvn/version "0.23.1" :exclusions [io.github.bonede/tree-sitter]}
        io.github.bonede/tree-sitter-c
        {:mvn/version "0.23.2" :exclusions [io.github.bonede/tree-sitter]}
        io.github.bonede/tree-sitter-cpp
        {:mvn/version "0.23.4" :exclusions [io.github.bonede/tree-sitter]}
        io.github.bonede/tree-sitter-ruby
        {:mvn/version "0.23.1" :exclusions [io.github.bonede/tree-sitter]}
        io.github.bonede/tree-sitter-php
        {:mvn/version "0.23.11" :exclusions [io.github.bonede/tree-sitter]}
        io.github.bonede/tree-sitter-bash
        {:mvn/version "0.23.3" :exclusions [io.github.bonede/tree-sitter]}
        io.github.bonede/tree-sitter-clojure
        {:mvn/version "0.0.12a" :exclusions [io.github.bonede/tree-sitter]}}
 :aliases
 {:dev {:extra-paths ["dev"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1"
                       :git/sha "dfb30dd"}}
         :jvm-opts ["--enable-native-access=ALL-UNNAMED"]
         :main-opts ["-m" "cognitect.test-runner"]}
  :bench {:extra-paths ["bench"]
          :jvm-opts ["--enable-native-access=ALL-UNNAMED"]
          :main-opts ["-m" "llm-context.benchmark"]}
  :build {:deps {io.github.clojure/tools.build {:mvn/version "0.10.8"}}
          :ns-default build}}}
