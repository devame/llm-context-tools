{:paths ["src" "resources"]
 :deps {org.clojure/clojure {:mvn/version "1.12.0"}
        org.datalevin/datalevin-embedded {:mvn/version "0.10.18"}
        io.github.tree-sitter/jtreesitter {:mvn/version "0.26.1"}
        io.github.bonede/tree-sitter {:mvn/version "0.25.3"}
        io.github.bonede/tree-sitter-javascript
        {:mvn/version "0.23.1"
         :exclusions [io.github.bonede/tree-sitter]}}
 :aliases
 {:dev {:extra-paths ["dev"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1"
                       :git/sha "dfb30dd"}}
         :jvm-opts ["--enable-native-access=ALL-UNNAMED"]
         :main-opts ["-m" "cognitect.test-runner"]}
  :build {:deps {io.github.clojure/tools.build {:mvn/version "0.10.8"}}
          :ns-default build}}}
